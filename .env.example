OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:8501
OPENROUTER_X_TITLE=RAG_BIOS

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Idiomas para PDFs y DOCX procesados con unstructured.
# Usa codigos separados por coma, por ejemplo: spa o spa,eng
DOCUMENT_LANGUAGES=spa,eng
# Si esta en true, reutiliza indices guardados en disco para el mismo set de archivos.
PERSISTENT_INDEX_CACHE=true
# Carpeta local para guardar el indice FAISS, documentos y manifest del cache persistente.
INDEX_CACHE_DIR=.rag_cache/indexes
# Cantidad de turnos recientes (usuario + asistente) usados para resolver preguntas de seguimiento.
CHAT_MEMORY_TURNS=3
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=6
RETRIEVAL_MULTIPLIER=3
REQUIRE_CITATIONS=true
TEMPERATURE=0.0
LOG_LEVEL=INFO
